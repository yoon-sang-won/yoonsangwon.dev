---
import BaseLayout from '../layouts/BaseLayout.astro';
import { urlFor } from '../lib/site';
---

<BaseLayout title="페이지를 찾을 수 없음" description="요청한 페이지를 찾을 수 없습니다." noindex canonicalPath="404.html">
  <article class="content">
    <h1>페이지를 찾을 수 없습니다</h1>
    <p>주소가 바뀌었거나 존재하지 않는 페이지입니다.</p>
    <ul class="plain-links">
      <li><a href={urlFor()}>홈으로 이동</a></li>
      <li><a href={urlFor('archive/')}>Archive에서 글 찾기</a></li>
    </ul>
  </article>
</BaseLayout>
